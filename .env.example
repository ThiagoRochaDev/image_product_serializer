# Chave da API Gemini (obrigatória para o cenário estruturado)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Chave da Stability AI (necessária apenas se SD_BACKEND=api)
# Obtenha em: https://platform.stability.ai/account/keys
STABILITY_API_KEY=sua_chave_stability_aqui

# Backend do Stable Diffusion
# Valores: "mock" (padrão) | "api" | "local"
SD_BACKEND=mock
